        <mxCell id="212" value="&lt;b&gt;&lt;font color=&quot;#82b366&quot;&gt;Solution&lt;/font&gt;&lt;/b&gt; &amp;nbsp;one-sided NVSHMEM direct pull + micro-batch pipeline" style="text;html=1;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=11;" vertex="1" parent="200">
          <mxGeometry x="22" y="172" width="460" height="20" as="geometry" />
        </mxCell>

        <!-- two step boxes -->
        <mxCell id="213" value="&lt;b&gt;1. One-sided direct pull&lt;/b&gt;&lt;br&gt;&lt;font style=&quot;font-size:9px;&quot;&gt;NVSHMEM: pull KV on-demand&lt;br&gt;independent, no barrier&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=1;verticalAlign=top;align=center;" vertex="1" parent="200">
