        <!-- timing models -->
        <mxCell id="216d" value="&lt;font color=&quot;#444444&quot;&gt;T&lt;sub&gt;pull&lt;/sub&gt; = max&lt;sub&gt;d&lt;/sub&gt; max&lt;sub&gt;j&amp;#8800;d&lt;/sub&gt; ( &amp;#945; + |K&lt;sub&gt;d,j&lt;/sub&gt;| &amp;#183; B&lt;sub&gt;kv&lt;/sub&gt; &amp;#183; d&lt;sub&gt;head&lt;/sub&gt; / &amp;#946; )&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="22" y="266" width="458" height="20" as="geometry" />
        </mxCell>
        <mxCell id="216y" value="&lt;font color=&quot;#444444&quot;&gt;T&lt;sub&gt;pipeline&lt;/sub&gt; = max(T&lt;sub&gt;pull&lt;/sub&gt;, T&lt;sub&gt;comp&lt;/sub&gt;) + &amp;#949;&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=10;" vertex="1" parent="200">
          <mxGeometry x="22" y="290" width="458" height="18" as="geometry" />
        </mxCell>
        <mxCell id="216x" value="&lt;font style=&quot;font-size:9px;&quot; color=&quot;#888888&quot;&gt;&amp;#945; = latency, &amp;#946; = bandwidth, &amp;#949; = pipeline startup/drain overhead&lt;/font&gt;" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;" vertex="1" parent="200">
